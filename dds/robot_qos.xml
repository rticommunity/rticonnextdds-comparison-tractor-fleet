<!--
  robot_qos.xml — QoS profiles for the the DDS approach tractor fleet.

  Design principle: inherit from the RTI *Pattern* profiles rather than
  Generic profiles.  Each Pattern already encodes the right combination
  of reliability / durability / history for its communication pattern,
  so our overrides are minimal — only liveliness and deadline tuning.

  Pattern cheat-sheet (from BuiltinProfiles.documentationONLY.xml):
    Pattern.PeriodicData    — BEST_EFFORT, VOLATILE, KEEP_LAST 1, deadline
    Pattern.Streaming       — alias for PeriodicData (loss-tolerant periodic)
    Pattern.ReliableStreaming — RELIABLE, KEEP_LAST 1, depth 100
    Pattern.Event           — RELIABLE, KEEP_ALL, liveliness 4 s
    Pattern.AlarmEvent      — alias for Event
    Pattern.Status          — RELIABLE, TRANSIENT_LOCAL, KEEP_LAST 1
    Pattern.AlarmStatus     — alias for Status
    Pattern.LastValueCache  — RELIABLE, TRANSIENT_LOCAL, KEEP_LAST 1
    Pattern.RPC             — RELIABLE, KEEP_ALL, tuned heartbeat/NACK

  Note: In 7.6.0 the Pattern profiles live in BuiltinQosLib (no longer
  experimental).  BuiltinQosLibExp is a deprecated compatibility alias.
-->
<dds xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
     xsi:noNamespaceSchemaLocation="https://community.rti.com/schema/7.6.0/rti_dds_profiles.xsd">

    <qos_library name="RobotQosLibrary">

        <!-- ============================================================
             KinematicState  (10 Hz, BEST_EFFORT, VOLATILE)
             Pattern.PeriodicData gives us best-effort + deadline.
             We tighten the deadline to match 10 Hz and add 100 ms
             liveliness for presence detection.
             ============================================================ -->
        <qos_profile name="KinematicStateProfile"
                     base_name="BuiltinQosLib::Pattern.PeriodicData">
            <datawriter_qos>
                <deadline>
                    <period>
                        <sec>0</sec>
                        <nanosec>200000000</nanosec> <!-- 200 ms (2× the 100 ms period) -->
                    </period>
                </deadline>
                <liveliness>
                    <kind>AUTOMATIC_LIVELINESS_QOS</kind>
                    <lease_duration>
                        <sec>0</sec>
                        <nanosec>100000000</nanosec> <!-- 100 ms -->
                    </lease_duration>
                </liveliness>
            </datawriter_qos>
            <datareader_qos>
                <deadline>
                    <period>
                        <sec>0</sec>
                        <nanosec>500000000</nanosec> <!-- 500 ms — generous for reader -->
                    </period>
                </deadline>
                <liveliness>
                    <kind>AUTOMATIC_LIVELINESS_QOS</kind>
                    <lease_duration>
                        <sec>0</sec>
                        <nanosec>100000000</nanosec> <!-- 100 ms -->
                    </lease_duration>
                </liveliness>
            </datareader_qos>
        </qos_profile>

        <!-- ============================================================
             OperationalState  (on-change, RELIABLE, TRANSIENT_LOCAL)
             Pattern.Status: reliable + transient-local + keep-last 1.
             We add 100 ms liveliness for presence detection.
             ============================================================ -->
        <qos_profile name="OperationalStateProfile"
                     base_name="BuiltinQosLib::Pattern.Status">
            <datawriter_qos>
                <liveliness>
                    <kind>AUTOMATIC_LIVELINESS_QOS</kind>
                    <lease_duration>
                        <sec>0</sec>
                        <nanosec>100000000</nanosec> <!-- 100 ms -->
                    </lease_duration>
                </liveliness>
            </datawriter_qos>
            <datareader_qos>
                <liveliness>
                    <kind>AUTOMATIC_LIVELINESS_QOS</kind>
                    <lease_duration>
                        <sec>0</sec>
                        <nanosec>100000000</nanosec> <!-- 100 ms -->
                    </lease_duration>
                </liveliness>
            </datareader_qos>
        </qos_profile>

        <!-- ============================================================
             Intent  (on-change, RELIABLE, TRANSIENT_LOCAL)
             Pattern.LastValueCache: reliable + transient-local + keep-last 1.
             Late joiners get the last published intent for each robot.
             We add 100 ms liveliness for presence detection.
             ============================================================ -->
        <qos_profile name="IntentProfile"
                     base_name="BuiltinQosLib::Pattern.LastValueCache">
            <datawriter_qos>
                <liveliness>
                    <kind>AUTOMATIC_LIVELINESS_QOS</kind>
                    <lease_duration>
                        <sec>0</sec>
                        <nanosec>100000000</nanosec> <!-- 100 ms -->
                    </lease_duration>
                </liveliness>
            </datawriter_qos>
            <datareader_qos>
                <liveliness>
                    <kind>AUTOMATIC_LIVELINESS_QOS</kind>
                    <lease_duration>
                        <sec>0</sec>
                        <nanosec>100000000</nanosec> <!-- 100 ms -->
                    </lease_duration>
                </liveliness>
            </datareader_qos>
        </qos_profile>

        <!-- ============================================================
             Telemetry  (1 Hz, BEST_EFFORT, VOLATILE)
             Pattern.Streaming: best-effort periodic, loss tolerable.
             No liveliness needed — covered by KinematicState.
             We tighten the deadline to 1 Hz.
             ============================================================ -->
        <qos_profile name="TelemetryProfile"
                     base_name="BuiltinQosLib::Pattern.Streaming">
            <datawriter_qos>
                <deadline>
                    <period>
                        <sec>2</sec>
                        <nanosec>0</nanosec> <!-- 2 s (2× the 1 s period) -->
                    </period>
                </deadline>
            </datawriter_qos>
            <datareader_qos>
                <deadline>
                    <period>
                        <sec>5</sec>
                        <nanosec>0</nanosec> <!-- 5 s — generous for reader -->
                    </period>
                </deadline>
            </datareader_qos>
        </qos_profile>

        <!-- ============================================================
             VideoFrame  (~5 fps, BEST_EFFORT, VOLATILE)
             Pattern.Streaming: best-effort periodic, dropped frames OK.
             No liveliness needed.
             ============================================================ -->
        <qos_profile name="VideoProfile"
                     base_name="BuiltinQosLib::Pattern.Streaming">
            <datawriter_qos>
                <deadline>
                    <period>
                        <sec>1</sec>
                        <nanosec>0</nanosec> <!-- 1 s (generous for ~5 fps) -->
                    </period>
                </deadline>
            </datawriter_qos>
            <datareader_qos>
                <deadline>
                    <period>
                        <sec>2</sec>
                        <nanosec>0</nanosec>
                    </period>
                </deadline>
            </datareader_qos>
        </qos_profile>

        <!-- ============================================================
             CommandRequest / CommandResponse  (RELIABLE, KEEP_ALL, VOLATILE)
             Pattern.RPC: reliable + keep-all + tuned heartbeat/NACK
             timing for low-latency request/reply.  Every command must
             be delivered; no late-joiner need.
             ============================================================ -->
        <qos_profile name="CommandProfile"
                     base_name="BuiltinQosLib::Pattern.RPC"/>

        <!-- ============================================================
             SlotRequest / SlotOffer / SlotConfirm / SlotAssignment /
             SlotRelease / SlotReleaseAck  (RELIABLE, KEEP_ALL, VOLATILE)
             Pattern.RPC: charging negotiation is correlated request/reply;
             same low-latency ACK recovery as commands.
             ============================================================ -->
        <qos_profile name="SlotNegotiationProfile"
                     base_name="BuiltinQosLib::Pattern.RPC"/>

        <!-- ============================================================
             StationStatus  (on-change, RELIABLE, TRANSIENT_LOCAL)
             Pattern.Status: reliable + transient-local + keep-last 1.
             UI late joiners need current station state.
             ============================================================ -->
        <qos_profile name="StationStatusProfile"
                     base_name="BuiltinQosLib::Pattern.Status"/>

        <!-- ============================================================
             CoveragePoint  (on-change, RELIABLE, TRANSIENT_LOCAL)
             Published when a tractor is actively working a path.
             Distance-filtered at source (≥1 arena unit between samples).

             Pattern.Status gives RELIABLE + TRANSIENT_LOCAL + KEEP_LAST 1.
             We override to KEEP_ALL with bounded resource limits so the
             writer's TRANSIENT_LOCAL cache holds the full trail — late-
             joining UIs receive every coverage point automatically.
             ============================================================ -->
        <qos_profile name="CoverageProfile"
                     base_name="BuiltinQosLib::Pattern.Status">
            <datawriter_qos>
                <history>
                    <kind>KEEP_LAST_HISTORY_QOS</kind>
                    <depth>1000</depth>
                </history>
                <resource_limits>
                    <max_samples>10000</max_samples>
                    <max_samples_per_instance>2000</max_samples_per_instance>
                </resource_limits>
                <durability>
                    <kind>PERSISTENT_DURABILITY_QOS</kind>
                </durability>
            </datawriter_qos>
            <datareader_qos>
                <history>
                    <kind>KEEP_LAST_HISTORY_QOS</kind>
                    <depth>1000</depth>
                </history>
                <resource_limits>
                    <max_samples>10000</max_samples>
                    <max_samples_per_instance>2000</max_samples_per_instance>
                </resource_limits>
                <durability>
                    <kind>PERSISTENT_DURABILITY_QOS</kind>
                </durability>
            </datareader_qos>
        </qos_profile>

    </qos_library>
</dds>
